# Clerk (https://clerk.com — free tier)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Neon PostgreSQL (https://neon.tech — free tier)
DATABASE_URL=postgres://...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (https://console.cloud.google.com)
# Enable: Google Calendar API, Google Drive API
# OAuth scopes: calendar.readonly, drive.readonly
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Notion OAuth (https://www.notion.so/my-integrations)
NOTION_CLIENT_ID=...
NOTION_CLIENT_SECRET=...

# Cron secret (any random string)
CRON_SECRET=your-random-secret-here
